---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ManualCard from "../../components/ManualCard.astro";
import TapeLabel from "../../components/field/TapeLabel.astro";
import Doodle from "../../components/field/Doodle.astro";
import { getCollection } from "astro:content";
import {
	compareManualNumbers,
	getManualChapter,
	manualChapters,
} from "../../lib/manual-nav";

const allManual = (await getCollection("manual", ({ data }) => !data.draft))
	.sort((a, b) => compareManualNumbers(a.data.number, b.data.number));

const chapterNumbers = [...new Set(allManual.map(entry => getManualChapter(entry.data.number)))]
	.sort((a, b) => a - b);
---

<BaseLayout
	title="Manual"
	description="The Pooly reference manual. Everything about clips, views, instruments, and more."
>
	<div class="manual-index">
		<Doodle name="cat" class="manual-doodle-cat" color="var(--color-accent)" width="170px" rotate="-6deg" opacity="0.55" alt="" />
		<header class="manual-header">
			<TapeLabel rotate="-1deg">Reference</TapeLabel>
			<h1>Manual</h1>
			<p class="manual-subtitle">Everything you need to know about Pooly.</p>
			<Doodle name="no_music" class="manual-doodle-nomusic" color="var(--color-clay)" width="140px" rotate="9deg" opacity="0.5" alt="" />
		</header>

		<div class="manual-cards">
			<Doodle name="notes" class="manual-doodle-notes" color="var(--color-note)" width="180px" rotate="-3deg" opacity="0.45" alt="" />
			{chapterNumbers.map(chapterNumber => {
				const entries = allManual.filter(
					entry => getManualChapter(entry.data.number) === chapterNumber,
				);
				if (entries.length === 0) return null;

				const primaryEntry = entries[0];

				return (
					<ManualCard
						number={String(chapterNumber)}
						title={manualChapters[chapterNumber]}
						description={primaryEntry.data.description}
						href={`/manual/${primaryEntry.id}/`}
					/>
				);
			})}
		</div>
	</div>
</BaseLayout>

<style>
	.manual-index {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: var(--space-2xl) var(--space-md);
		position: relative;
	}

	.manual-index :global(.manual-doodle-cat) {
		position: absolute;
		top: 0.5rem;
		left: -1rem;
		z-index: 1;
		display: none;
	}

	.manual-header {
		text-align: center;
		margin-bottom: var(--space-3xl);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-md);
		position: relative;
	}

	.manual-header :global(.manual-doodle-nomusic) {
		position: absolute;
		top: -0.5rem;
		right: 6%;
		z-index: 1;
		display: none;
	}

	.manual-cards {
		position: relative;
	}

	.manual-cards :global(.manual-doodle-notes) {
		position: absolute;
		bottom: -3rem;
		left: 40%;
		z-index: 2;
		display: none;
	}

	@media (min-width: 52rem) {
		.manual-index :global(.manual-doodle-cat),
		.manual-header :global(.manual-doodle-nomusic),
		.manual-cards :global(.manual-doodle-notes) {
			display: inline-block;
		}
	}

	.manual-header h1 {
		margin-bottom: 0;
	}

	.manual-subtitle {
		font-size: var(--text-xl);
		color: var(--color-text-soft);
	}

	.manual-cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-sm);
	}

	@media (min-width: 40rem) {
		.manual-cards {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 64rem) {
		.manual-cards {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
