---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ManualCard from "../../components/ManualCard.astro";
import TapeLabel from "../../components/field/TapeLabel.astro";
import { getCollection } from "astro:content";
import {
	compareManualNumbers,
	getManualChapter,
	manualChapters,
} from "../../lib/manual-nav";

const allManual = (await getCollection("manual", ({ data }) => !data.draft))
	.sort((a, b) => compareManualNumbers(a.data.number, b.data.number));

const chapterNumbers = [...new Set(allManual.map(entry => getManualChapter(entry.data.number)))]
	.sort((a, b) => a - b);
---

<BaseLayout
	title="Manual"
	description="The Pooly reference manual. Everything about clips, views, instruments, and more."
>
	<div class="manual-index">
		<header class="manual-header">
			<TapeLabel rotate="-1deg">Reference</TapeLabel>
			<h1>Manual</h1>
			<p class="manual-subtitle">Everything you need to know about Pooly.</p>
		</header>

		{chapterNumbers.map(chapterNumber => {
			const entries = allManual.filter(
				entry => getManualChapter(entry.data.number) === chapterNumber,
			);
			if (entries.length === 0) return null;

			const chapterTitle = manualChapters[chapterNumber];
			const isSinglePageChapter = entries.length === 1 && entries[0].data.number === String(chapterNumber);

			return (
				<div class="manual-group">
					<div class="manual-group-header">
						<h2>{chapterNumber}. {chapterTitle}</h2>
					</div>
					<div class="manual-group-cards">
						{entries.map(entry => (
							<ManualCard
								number={entry.data.number}
								title={entry.data.title}
								description={entry.data.description}
								href={`/manual/${entry.id}/`}
								showTitle={!isSinglePageChapter || entry.data.number.includes(".")}
							/>
						))}
					</div>
				</div>
			);
		})}
	</div>
</BaseLayout>

<style>
	.manual-index {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: var(--space-2xl) var(--space-md);
	}

	.manual-header {
		text-align: center;
		margin-bottom: var(--space-3xl);
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-md);
	}

	.manual-header h1 {
		margin-bottom: 0;
	}

	.manual-subtitle {
		font-size: var(--text-xl);
		color: var(--color-text-soft);
	}

	.manual-group {
		margin-bottom: var(--space-3xl);
	}

	.manual-focus {
		margin-bottom: var(--space-3xl);
	}

	.manual-focus::after {
		content: "";
		display: block;
		clear: both;
	}

	.manual-focus h2 {
		font-size: clamp(var(--text-xl), 3vw, var(--text-2xl));
		margin-bottom: var(--space-sm);
	}

	.manual-focus p {
		max-width: 46rem;
		color: var(--color-text-soft);
		text-wrap: pretty;
		overflow-wrap: anywhere;
	}

	.manual-focus-links {
		margin-top: var(--space-md);
		padding-left: var(--space-xl);
		max-width: 46rem;
	}

	.manual-focus-links li {
		margin-bottom: var(--space-xs);
		color: var(--color-text-soft);
	}

	.manual-group-header {
		margin-bottom: var(--space-lg);
	}

	.manual-group-header h2 {
		font-size: var(--text-xl);
		margin-bottom: var(--space-xs);
	}

	.manual-group-cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-sm);
	}

	@media (min-width: 40rem) {
		.manual-group-cards {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 64rem) {
		.manual-group-cards {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
