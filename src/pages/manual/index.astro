---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ManualCard from "../../components/ManualCard.astro";
import { getCollection } from "astro:content";
import {
	compareManualNumbers,
	getManualChapter,
	manualChapters,
} from "../../lib/manual-nav";

const allManual = (await getCollection("manual", ({ data }) => !data.draft))
	.sort((a, b) => compareManualNumbers(a.data.number, b.data.number));

const chapterNumbers = [...new Set(allManual.map(entry => getManualChapter(entry.data.number)))]
	.sort((a, b) => a - b);
---

<BaseLayout
	title="Manual"
	description="The Pooly reference manual. Everything about clips, views, instruments, and more."
>
	<div class="manual-index">
		<header class="manual-header">
			<h1>Manual</h1>
			<p class="manual-subtitle">Everything you need to know about Pooly.</p>
		</header>

		<section class="manual-focus">
			<figure class="manual-media" data-wrap="right">
				<img
					src="/images/application-screenshots/detail.png"
					alt="Pooly Clip Detail view showing voice controls and drum clip slots."
					width="686"
					height="1029"
					loading="lazy"
				/>
				<figcaption>
					Clip Detail on an instrument track: edit voice parameters and clip content in one place.
				</figcaption>
			</figure>
			<h2>Detail View and Clip Detail</h2>
			<p>
				Clip Detail is where you edit note content, shape sounds, and manage per-clip controls.
				If you are learning this part of Pooly, start with these sections:
			</p>
			<ul class="manual-focus-links">
				<li>
					<a href="/manual/core-concepts/#16-detail-view">1.6 Detail View</a> for the editing
					model and panel layout.
				</li>
				<li>
					<a href="/manual/views/clip-launcher/">3 Clip Launcher</a> for how clips open into
					Detail View from the grid.
				</li>
				<li>
					<a href="/manual/views/browser/">2 Browser</a> for how instrument and effect browsing
					works inside Clip Detail.
				</li>
			</ul>
		</section>

		{chapterNumbers.map(chapterNumber => {
			const entries = allManual.filter(
				entry => getManualChapter(entry.data.number) === chapterNumber,
			);
			if (entries.length === 0) return null;

			const chapterTitle = manualChapters[chapterNumber];
			const isSinglePageChapter = entries.length === 1 && entries[0].data.number === String(chapterNumber);

			return (
				<div class="manual-group">
					<div class="manual-group-header">
						<h2>{chapterNumber}. {chapterTitle}</h2>
					</div>
					<div class="manual-group-cards">
						{entries.map(entry => (
							<ManualCard
								number={entry.data.number}
								title={entry.data.title}
								description={entry.data.description}
								href={`/manual/${entry.id}/`}
								showTitle={!isSinglePageChapter || entry.data.number.includes(".")}
							/>
						))}
					</div>
				</div>
			);
		})}
	</div>
</BaseLayout>

<style>
	.manual-index {
		max-width: var(--content-max);
		margin: 0 auto;
		padding: var(--space-2xl) var(--space-md);
	}

	.manual-header {
		text-align: center;
		margin-bottom: var(--space-3xl);
	}

	.manual-header h1 {
		margin-bottom: var(--space-sm);
	}

	.manual-subtitle {
		font-size: var(--text-xl);
		color: var(--color-text-soft);
	}

	.manual-group {
		margin-bottom: var(--space-3xl);
	}

	.manual-focus {
		margin-bottom: var(--space-3xl);
	}

	.manual-focus::after {
		content: "";
		display: block;
		clear: both;
	}

	.manual-focus h2 {
		font-size: clamp(var(--text-xl), 3vw, var(--text-2xl));
		margin-bottom: var(--space-sm);
	}

	.manual-focus p {
		max-width: 46rem;
		color: var(--color-text-soft);
		text-wrap: pretty;
		overflow-wrap: anywhere;
	}

	.manual-focus-links {
		margin-top: var(--space-md);
		padding-left: var(--space-xl);
		max-width: 46rem;
	}

	.manual-focus-links li {
		margin-bottom: var(--space-xs);
		color: var(--color-text-soft);
	}

	.manual-group-header {
		margin-bottom: var(--space-lg);
	}

	.manual-group-header h2 {
		font-size: var(--text-xl);
		margin-bottom: var(--space-xs);
	}

	.manual-group-cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-sm);
	}

	@media (min-width: 40rem) {
		.manual-group-cards {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (min-width: 64rem) {
		.manual-group-cards {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
