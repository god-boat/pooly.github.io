---
import BaseLayout from "../layouts/BaseLayout.astro";
import TapeLabel from "../components/field/TapeLabel.astro";
import HandNote from "../components/field/HandNote.astro";
import Sticker from "../components/field/Sticker.astro";
import FeatureBlock from "../components/field/FeatureBlock.astro";

const socialLinks = [
	{ label: "Manual", href: "/manual/", internal: true },
	{ label: "Discord", href: "https://discord.gg/zbNVJYBtw7" },
	{ label: "Threads", href: "https://www.threads.net/@poolydaw" },
	{ label: "Patreon", href: "https://patreon.com/godboat" },
	{ label: "Instagram", href: "https://www.instagram.com/poolydaw" },
	{ label: "YouTube", href: "https://www.youtube.com/@poolydaw" },
];
---

<BaseLayout
	title="Pooly"
	description="A touch-first music workstation for sketching, sampling, performing, and arranging on phones, tablets, and desktop."
>
	<section class="hero">
		<div class="hero-bg"></div>
		<div class="hero-content">
			<TapeLabel rotate="-1deg">Portable Studio</TapeLabel>
			<h1>Make music before<br />the idea disappears.</h1>
			<p class="hero-subtitle">
				Pooly is a touch-first music workstation for sketching,
				sampling, performing, and arranging on phones, tablets, and desktop.
			</p>
			<nav class="social-links" aria-label="Pooly links">
				{socialLinks.map(link => (
					<a
						class="social-link"
						href={link.href}
						{...(link.internal ? {} : { target: "_blank", rel: "noopener noreferrer" })}
					>
						{link.label}
					</a>
				))}
			</nav>
		</div>
		<div class="hero-device">
			<img
				src="/images/brand/poolyHero01.png"
				alt="Pooly clip launcher"
				width="800"
				height="600"
			/>
		</div>
		<HandNote class="note note-a">Sketch, loop, build.</HandNote>
		<HandNote class="note note-b">Take it anywhere.</HandNote>
	</section>

	<div class="features-stack">
		<FeatureBlock
			number="01"
			title="Built for the first 30 seconds of an idea"
			body="Capture, sketch, and loop in moments. Clips, patterns, and variations — fast."
			image="/images/placeholders/screen-1.svg"
			imageAlt="Pooly pattern editor"
		/>

		<FeatureBlock
			number="02"
			title="Playable, not just editable"
			body="Scenes, mutes, and macros put your song in your hands. Less spreadsheet, more instrument."
			image="/images/placeholders/screen-2.svg"
			imageAlt="Pooly performance view"
			reverse
		/>

		<FeatureBlock
			number="03"
			title="A small studio of instruments"
			body="FM synths, samplers, expressive kits, and everyday sounds — over 650 built-in voices to start from."
			image="/images/placeholders/screen-3.svg"
			imageAlt="Pooly instruments"
		/>

		<FeatureBlock
			number="04"
			title="Finish the idea"
			body="Arrange, refine, and build your song all in one place. Turn sketches into songs without moving to a desktop."
			image="/images/placeholders/screen-4.svg"
			imageAlt="Pooly arrangement view"
			reverse
		/>
	</div>

	<section class="cta-section">
		<Sticker color="var(--color-clay)" rotate="-4deg" class="cta-sticker">Touch-first<br />DAW</Sticker>
		<div class="cta-content">
			<h2>Ready to start creating?</h2>
			<p class="cta-lead">
				Explore guides, read the manual, or join the community.
			</p>
			<div class="cta-cards">
				<a href="/learn/" class="cta-card">
					<span class="cta-card-title">Learn Pooly</span>
					<span class="cta-card-desc">Step-by-step guides for getting started</span>
				</a>
				<a href="/manual/" class="cta-card">
					<span class="cta-card-title">Manual</span>
					<span class="cta-card-desc">In-depth reference for every feature</span>
				</a>
				<a href="https://discord.gg/zbNVJYBtw7" class="cta-card" target="_blank" rel="noopener noreferrer">
					<span class="cta-card-title">Discord</span>
					<span class="cta-card-desc">Join the community and share your music</span>
				</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* ── Hero ── */

	.hero {
		position: relative;
		overflow: hidden;
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-2xl);
		padding: clamp(4rem, 8vw, 8rem) clamp(1.25rem, 6vw, 6rem);
		min-height: 80svh;
		align-items: center;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		z-index: -1;
		background:
			radial-gradient(ellipse 80% 60% at 50% 40%, rgba(201, 185, 143, 0.06), transparent 70%),
			linear-gradient(to bottom, transparent 70%, var(--color-bg));
	}

	.hero-content {
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
	}

	.hero h1 {
		font-size: clamp(2.4rem, 8vw, 4.2rem);
		font-weight: 700;
		line-height: 0.95;
		letter-spacing: -0.03em;
		text-transform: lowercase;
	}

	.hero-subtitle {
		font-size: clamp(var(--text-base), 2.2vw, var(--text-lg));
		color: var(--color-text-soft);
		line-height: 1.6;
		max-width: 32rem;
	}

	.hero-device {
		display: none;
	}

	.hero-device img {
		width: 100%;
		border-radius: var(--radius-xl);
		box-shadow: var(--shadow-lg);
	}

	.note {
		position: absolute;
		display: none;
	}

	.social-links {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.25rem;
		width: 100%;
		max-width: 28rem;
	}

	.social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 3rem;
		padding: 0.75rem 1rem;
		border: none;
		border-radius: var(--radius-sm);
		background: var(--color-bg-glass-strong);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		text-decoration: none;
		text-transform: lowercase;
		font-size: 0.72rem;
		font-weight: 400;
		letter-spacing: 0.14em;
		color: var(--color-text);
		transition:
			transform 180ms ease,
			background-color 180ms ease;
	}

	.social-link:hover,
	.social-link:focus-visible {
		background: var(--color-bg-glass-strong);
		transform: translateY(-2px);
		color: var(--color-text);
	}

	@media (min-width: 40rem) {
		.social-links {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (min-width: 52rem) {
		.hero {
			grid-template-columns: 0.9fr 1.2fr;
			gap: clamp(2rem, 5vw, 4rem);
		}

		.hero-device {
			display: block;
			transform: rotate(-2deg);
		}

		.note {
			display: block;
		}

		.note-a {
			top: 18%;
			right: 38%;
		}

		.note-b {
			top: 34%;
			right: 4%;
		}

		.social-links {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (min-width: 64rem) {
		.social-links {
			grid-template-columns: repeat(6, minmax(0, 1fr));
		}
	}

	/* ── Features ── */

	.features-stack {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xl);
		max-width: var(--content-max);
		margin: 0 auto;
		padding: var(--space-3xl) var(--space-md);
	}

	/* ── CTA ── */

	.cta-section {
		position: relative;
		text-align: center;
		padding: var(--space-4xl) var(--space-md);
		max-width: var(--content-max);
		margin: 0 auto;
	}

	.cta-sticker {
		position: absolute;
		top: var(--space-xl);
		right: var(--space-xl);
		display: none;
	}

	@media (min-width: 52rem) {
		.cta-sticker {
			display: inline-grid;
		}
	}

	.cta-content {
		max-width: var(--content-max);
		margin: 0 auto;
	}

	.cta-lead {
		color: var(--color-text-soft);
		font-size: var(--text-lg);
		margin-top: var(--space-md);
		line-height: 1.6;
	}

	.cta-cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-md);
		margin-top: var(--space-2xl);
		text-align: left;
	}

	.cta-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		padding: var(--space-xl);
		border-radius: var(--radius-2xl);
		background: var(--color-paper);
		border: 1px solid var(--color-border);
		color: var(--color-text);
		text-decoration: none;
		transition: all var(--duration-normal) var(--ease-out);
	}

	.cta-card:hover {
		background: var(--color-paper-soft);
		border-color: var(--color-border-strong);
		transform: translateY(-2px);
		color: var(--color-text);
	}

	.cta-card-title {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: var(--text-lg);
	}

	.cta-card-desc {
		color: var(--color-text-soft);
		font-size: var(--text-sm);
	}

	@media (min-width: 40rem) {
		.cta-cards {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
