---
import BaseLayout from "../layouts/BaseLayout.astro";
import TapeLabel from "../components/field/TapeLabel.astro";
import HandNote from "../components/field/HandNote.astro";
import Sticker from "../components/field/Sticker.astro";
import FeatureBlock from "../components/field/FeatureBlock.astro";
import Doodle from "../components/field/Doodle.astro";

const socialLinks = [
	{ label: "Manual", href: "/manual/", internal: true },
	{ label: "Discord", href: "https://discord.gg/zbNVJYBtw7" },
	{ label: "Threads", href: "https://www.threads.net/@poolydaw" },
	{ label: "Patreon", href: "https://patreon.com/godboat" },
	{ label: "Instagram", href: "https://www.instagram.com/poolydaw" },
	{ label: "YouTube", href: "https://www.youtube.com/@poolydaw" },
];
---

<BaseLayout
	title="Pooly"
	description="A touch-first music workstation for sketching, sampling, performing, and arranging on phones, tablets, and desktop."
>
	<section class="hero">
		<div class="hero-bg"></div>

		<Doodle name="xy" class="hero-doodle-xy" color="var(--color-accent)" width="120px" rotate="-8deg" opacity="0.18" alt="" />
		<Doodle name="notes" class="hero-doodle-notes" color="var(--color-note)" width="30px" rotate="19deg" opacity="0.35" alt="" />

		<div class="hero-device">
			<div class="hero-device-frame">
				<img
					src="/images/brand/poolyHero01.png"
					alt="Pooly clip launcher"
					width="800"
					height="600"
				/>
			</div>

			<Doodle name="layout" class="hero-doodle-layout" color="var(--color-tape)" width="160px" rotate="-3deg" opacity="0.55" alt="" />

			<TapeLabel rotate="9deg" class="device-tape device-tape-a" color="light">Clip Launcher</TapeLabel>
			<Sticker rotate="-7deg" color="var(--color-olive)" class="device-sticker">Made on<br/>the bus</Sticker>
			<HandNote class="device-note device-note-a">^ scenes</HandNote>
			<HandNote class="device-note device-note-b">clips & patterns</HandNote>

			<div class="project-card">
				<span class="project-card-title">my-song-02.pool</span>
				<span class="project-card-meta">12 tracks · 202 bpm</span>
			</div>
		</div>

		<div class="hero-content">
			<TapeLabel rotate="-9.5deg" class="hero-tape">  Field Studio  </TapeLabel>
			<!-- <HandNote class="hero-tagline">Sketch, loop, build.</HandNote> -->
			<h1>Make music before<br />the idea disappears.</h1>
			<p class="hero-subtitle">
				Pooly is a touch-first music workstation for sketching,
				sampling, performing, and arranging on phones, tablets, and desktop.
			</p>
			<div class="hero-links-group">
				<HandNote class="hero-take-anywhere">take it anywhere →</HandNote>
				<nav class="social-links" aria-label="Pooly links">
					{socialLinks.map(link => (
						<a
							class="social-link"
							href={link.href}
							{...(link.internal ? {} : { target: "_blank", rel: "noopener noreferrer" })}
						>
							{link.label}
						</a>
					))}
				</nav>
			</div>
		</div>
	</section>

	<div class="features-stack">
		<FeatureBlock
			number="01"
			title="Built for the first 30 seconds of an idea"
			body="Capture, sketch, and loop in moments. Clips, patterns, and variations — fast."
			image="/images/application-screenshots/tracks.png"
			imageAlt="Pooly clip launcher and instrument detail"
		>
			<HandNote class="artifact artifact-01">catch it before it disappears ♪</HandNote>
			<Doodle slot="doodle" name="note" class="feature-doodle feature-doodle-01" color="var(--color-note)" width="80px" rotate="14deg" opacity="0.7" alt="" />
		</FeatureBlock>

		<FeatureBlock
			number="02"
			title="Playable, not just editable"
			body="Scenes, mutes, and macros put your song in your hands. Less spreadsheet, more instrument."
			image="/images/application-screenshots/arranger%20+%20launcher.png"
			imageAlt="Pooly arranger and clip launcher"
			reverse
		>
			<Doodle slot="doodle" name="strum" class="feature-doodle feature-doodle-02" color="var(--color-clay)" width="240px" rotate="-9deg" opacity="0.65" alt="" />
			<TapeLabel rotate="-9deg" class="artifact artifact-02" color="warm">  live performance  </TapeLabel>
		</FeatureBlock>

		<FeatureBlock
			number="03"
			title="A small studio of instruments"
			body="FM synths, samplers, expressive kits, and everyday sounds — over 550 built-in voices to start from."
			image="/images/application-screenshots/detail.png"
			imageAlt="Pooly instrument detail view"
		>
			<Sticker rotate="6deg" color="var(--color-blue)" class="artifact artifact-03">550+<br/>voices</Sticker>
			<Doodle slot="doodle" name="fm" class="feature-doodle feature-doodle-03" color="var(--color-blue)" width="160px" rotate="5deg" opacity="0.55" alt="" />
		</FeatureBlock>

		<FeatureBlock
			number="04"
			title="Finish the idea"
			body="Arrange, refine, and build your song all in one place. Turn sketches into songs without moving to a desktop."
			image="/images/application-screenshots/launcher%20+%20detail.png"
			imageAlt="Pooly tracks and arrangement view"
			reverse
		>
			<HandNote class="artifact artifact-04">sketch → song</HandNote>
			<Doodle slot="doodle" name="skecth" class="feature-doodle feature-doodle-04" color="var(--color-olive)" width="200px" rotate="-4deg" opacity="0.6" alt="" />
		</FeatureBlock>
	</div>

	<section class="cta-section">
		<Sticker color="var(--color-clay)" rotate="-6deg" class="cta-sticker">Start messy.<br/>Make it<br/>better.</Sticker>
		<Doodle name="bad_pooly" class="cta-doodle-pooly" color="var(--color-note)" width="120px" rotate="-7deg" opacity="0.5" alt="" />
		<Doodle name="were" class="cta-doodle-were" color="var(--color-accent)" width="70px" rotate="9deg" opacity="0.35" flip alt="" />
		<div class="cta-content">
			<h2>Join early access</h2>
			<p class="cta-lead">
				Help shape a music app built for ideas in motion.
				<br/>COMING SOON
			</p>
			<div class="cta-cards">
				<a href="/learn/" class="cta-card">
					<span class="cta-card-title">Learn Pooly</span>
					<span class="cta-card-desc">Step-by-step guides for getting started</span>
				</a>
				<a href="/manual/" class="cta-card">
					<span class="cta-card-title">Manual</span>
					<span class="cta-card-desc">In-depth reference for every feature</span>
				</a>
				<a href="https://discord.gg/zbNVJYBtw7" class="cta-card" target="_blank" rel="noopener noreferrer">
					<span class="cta-card-title">Discord</span>
					<span class="cta-card-desc">Join the community and share your music</span>
				</a>
			</div>
		</div>
	</section>
</BaseLayout>

<style>
	/* ── Hero ── */

	.hero {
		position: relative;
		overflow: visible;
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-2xl);
		padding:  clamp(1.25rem, 6vw, 6rem);
		min-height: 80svh;
		align-items: center;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		z-index: 0;
		/* background:
			radial-gradient(ellipse 80% 60% at 50% 40%, rgba(201, 185, 143, 0.06), transparent 70%),
			linear-gradient(to bottom, transparent 70%, var(--color-bg)); */
	}

	.hero-content {
		position: relative;
		z-index: 2;
		display: flex;
		flex-direction: column;
		gap: var(--space-lg);
	}

	.hero h1 {
		font-size: clamp(2.4rem, 8vw, 4.2rem);
		font-weight: 700;
		line-height: 0.95;
		letter-spacing: -0.03em;
		text-transform: lowercase;
	}

	.hero-subtitle {
		font-size: clamp(var(--text-base), 2.2vw, var(--text-lg));
		color: var(--color-text-soft);
		line-height: 1.6;
		max-width: 32rem;
	}

	/* ── Hero inline hand notes ── */

	.hero-content :global(.hero-tagline) {
		align-self: flex-start;
		font-size: 1.2rem;
		color: var(--color-note);
		margin-left: 0.25rem;
		transform: rotate(-2deg);
	}

	.hero-links-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		max-width: 28rem;
	}

	.hero-links-group :global(.hero-take-anywhere) {
		align-self: flex-start;
		font-size: 1.05rem;
		color: var(--color-note);
		margin-left: 0.75rem;
		transform: rotate(-1.5deg);
	}

	/* ── Hero tape (Field Studio) ── */

	.hero-content :global(.hero-tape) {
		align-self: flex-start;
		position: relative;
		z-index: 9;
		margin-bottom: -2.6rem;
		margin-left: -1rem;
	}

	/* ── Hero device with collage objects ── */

	.hero-device {
		position: absolute;
		top: 50%;
		right: -28%;
		width: 95%;
		max-width: 720px;
		z-index: 1;
		transform: translateY(-50%);
		opacity: 0.42;
		pointer-events: none;
	}

	.hero-device-frame {
		transform: rotate(-2deg);
	}

	.hero-device-frame img {
		width: 100%;
		border-radius: var(--radius-xl);
		box-shadow: var(--shadow-drop);
	}

	/* Hide collage objects on narrow where image is a faded backdrop */
	.hero-device :global(.device-tape),
	.hero-device :global(.device-sticker),
	.hero-device :global(.device-note),
	.project-card {
		display: none;
	}

	.hero-device :global(.device-tape) {
		position: absolute;
		z-index: 4;
	}

	.hero-device :global(.device-tape-a) {
		bottom: -1rem;
		left: 0%;
	}

	.hero-device :global(.device-sticker) {
		position: absolute;
		z-index: 4;
		top: 5rem;
		right: -4rem;
	}

	.hero-device :global(.device-note) {
		position: absolute;
		z-index: 4;
	}

	.hero-device :global(.device-note-a) {
		top: 28%;
		left: -3rem;
	}

	.hero-device :global(.device-note-b) {
		bottom: 22%;
		right: -2rem;
	}

	.project-card {
		position: absolute;
		z-index: 4;
		top: -1.2rem;
		left: 5%;
		flex-direction: column;
		gap: 2px;
		padding: 0.4rem 0.65rem;
		background: var(--color-paper);
		border: 1px solid var(--color-border-strong);
		border-radius: var(--radius-sm);
		transform: rotate(1deg);
		box-shadow: var(--shadow-drop);
	}

	.project-card-title {
		font-family: var(--font-body);
		font-size: 0.68rem;
		font-weight: 600;
		color: var(--color-text);
		letter-spacing: 0.02em;
	}

	.project-card-meta {
		font-size: 0.58rem;
		color: var(--color-text-muted);
		letter-spacing: 0.04em;
	}

	/* ── Social links ── */

	.social-links {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.25rem;
		width: 100%;
		max-width: 28rem;
	}

	.social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 3rem;
		padding: 0.75rem 1rem;
		border: none;
		border-radius: var(--radius-sm);
		background: var(--color-bg-glass-strong);
		box-shadow: var(--shadow-drop);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		text-decoration: none;
		text-transform: lowercase;
		font-size: 0.72rem;
		font-weight: 400;
		letter-spacing: 0.14em;
		color: var(--color-text);
		transition:
			transform 180ms ease,
			background-color 180ms ease;
	}

	.social-link:hover,
	.social-link:focus-visible {
		background: var(--color-bg-glass-strong);
		transform: translateY(-2px);
		color: var(--color-text);
	}

	@media (min-width: 40rem) {
		.social-links {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (min-width: 52rem) {
		.hero {
			grid-template-columns: 0.9fr 1.2fr;
			gap: clamp(2rem, 5vw, 4rem);
		}

		.hero-device {
			position: relative;
			top: auto;
			right: auto;
			width: auto;
			max-width: none;
			transform: none;
			opacity: 1;
			pointer-events: auto;
			grid-column: 2;
			grid-row: 1;
		}

		.hero-content {
			grid-column: 1;
			grid-row: 1;
		}

		.hero-device :global(.device-tape),
		.hero-device :global(.device-note) {
			display: block;
		}

		.hero-device :global(.device-sticker) {
			display: inline-grid;
		}

		.project-card {
			display: flex;
		}

		.social-links {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (min-width: 64rem) {
		.social-links {
			grid-template-columns: repeat(6, minmax(0, 1fr));
		}
	}

	/* ── Hero doodles ── */

	.hero :global(.hero-doodle-xy) {
		position: absolute;
		top: 8%;
		left: 4%;
		z-index: 0;
		display: none;
	}

	.hero :global(.hero-doodle-notes) {
		position: absolute;
		top: 20.5rem;
		left: 1rem;
		z-index: 1;
		display: none;
	}

	.hero-device :global(.hero-doodle-layout) {
		position: absolute;
		top: -8%;
		right: -10%;
		z-index: 3;
		display: none;
	}

	@media (min-width: 52rem) {
		.hero :global(.hero-doodle-xy),
		.hero :global(.hero-doodle-notes),
		.hero-device :global(.hero-doodle-layout) {
			display: inline-block;
		}
	}

	/* ── Features ── */

	.features-stack {
		display: flex;
		flex-direction: column;
		gap: var(--space-2xl);
		max-width: var(--content-max);
		margin: 0 auto;
		padding: var(--space-3xl) var(--space-md);
	}

	/* Per-section artifact positioning */
	.features-stack :global(.artifact) {
	position: absolute;
	pointer-events: none;
	}

	.features-stack :global(.artifact-01) {
		bottom: 2.5rem;
		right: 2rem;
		z-index: 3;
	}

	.features-stack :global(.artifact-02) {
		top: -26.5rem;
		right: -9rem;
		z-index: 3;
	}

	.features-stack :global(.artifact-03) {
		bottom: -3.5rem;
		left: -3rem;
		z-index: 0;
	}

	.features-stack :global(.artifact-04) {
		top: 2rem;
		left: 2rem;
		font-size: 1.1rem;
		z-index: 3;
	}

	/* Feature doodles overlap the screenshots */
	.features-stack :global(.feature-doodle) {
		position: absolute;
		pointer-events: none;
		display: none;
	}

	.features-stack :global(.feature-doodle-01) {
		top: -1.5rem;
		right: -1rem;
		z-index: 4;
	}

	.features-stack :global(.feature-doodle-02) {
		bottom: -2rem;
		left: -3rem;
		z-index: 4;
	}

	.features-stack :global(.feature-doodle-03) {
		top: -8rem;
		right: -8rem;
		z-index: 4;
	}

	.features-stack :global(.feature-doodle-04) {
		bottom: -3rem;
		right: -1.5rem;
		z-index: 4;
	}

	@media (min-width: 52rem) {
		.features-stack :global(.feature-doodle) {
			display: inline-block;
		}
	}

	/* ── CTA ── */

	.cta-section {
		position: relative;
		text-align: center;
		padding: var(--space-4xl) var(--space-md);
		max-width: var(--content-max);
		margin: 0 auto;
	}

	.cta-sticker {
		position: absolute;
		top: var(--space-xl);
		right: var(--space-2xl);
		display: none;
	}

	.cta-section :global(.cta-doodle-pooly) {
		position: absolute;
		top: 0;
		left: -1rem;
		z-index: 2;
		display: none;
	}

	.cta-section :global(.cta-doodle-were) {
		position: absolute;
		bottom: -2rem;
		right: 4%;
		z-index: 2;
		display: none;
	}

	@media (min-width: 52rem) {
		.cta-section :global(.cta-doodle-pooly),
		.cta-section :global(.cta-doodle-were) {
			display: inline-block;
		}
	}

	@media (min-width: 52rem) {
		.cta-sticker {
			display: inline-grid;
		}
	}

	.cta-content {
		max-width: var(--content-max);
		margin: 0 auto;
	}

	.cta-lead {
		color: var(--color-text-soft);
		font-size: var(--text-lg);
		margin-top: var(--space-md);
		line-height: 1.6;
	}

	.cta-cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-md);
		margin-top: var(--space-2xl);
		text-align: left;
	}

	.cta-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		padding: var(--space-xl);
		border-radius: var(--radius-2xl);
		background: var(--color-paper);
		border: 1px solid var(--color-border);
		box-shadow: var(--shadow-drop);
		color: var(--color-text);
		text-decoration: none;
		transition: all var(--duration-normal) var(--ease-out);
	}

	.cta-card:hover {
		background: var(--color-paper-soft);
		border-color: var(--color-border-strong);
		transform: translateY(-2px);
		color: var(--color-text);
	}

	.cta-card-title {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: var(--text-lg);
	}

	.cta-card-desc {
		color: var(--color-text-soft);
		font-size: var(--text-sm);
	}

	@media (min-width: 40rem) {
		.cta-cards {
			grid-template-columns: repeat(3, 1fr);
		}
	}
</style>
