---
import BaseLayout from "../layouts/BaseLayout.astro";
import FeatureCard from "../components/FeatureCard.astro";
import PageSection from "../components/PageSection.astro";
import GradientSection from "../components/GradientSection.astro";

const socialLinks = [
	{ label: "Manual", href: "https://pooly.studio/manual" },
	{ label: "Discord", href: "https://discord.gg/zbNVJYBtw7" },
	{ label: "Threads", href: "https://www.threads.net/@poolydaw" },
	{ label: "Patreon", href: "https://patreon.com/godboat" },
	{ label: "Instagram", href: "https://www.instagram.com/poolydaw" },
	{ label: "YouTube", href: "https://www.youtube.com/@poolydaw" },
];
---

<BaseLayout
	title="Pooly"
	description="A playful, mobile-first DAW for capturing ideas, building sounds, and arranging music anywhere."
>
	<section class="hero">
		<div class="hero-bg"></div>
		<div class="hero-content">
			<img
				src="/images/brand/pooly_icon_stacked.png"
				alt=""
				class="hero-logo"
				width="120"
				height="75"
			/>
			<h1>make music<br />anywhere</h1>
			<p class="hero-subtitle">
				A powerful DAW for capturing ideas, designing sounds,
				and arranging songs, on any device.
			</p>
			<nav class="social-links" aria-label="Pooly DAW social links">
				{socialLinks.map(link => (
					<a class="social-link" href={link.href} target="_blank" rel="noopener noreferrer">
						{link.label}
					</a>
				))}
			</nav>
		</div>
	</section>

	<GradientSection>
		<div class="section-header">
			<h2>Everything you need to make music</h2>
			<p class="section-lead">
				Pooly gives you patterns, clips, scenes, instruments, and a full arrangement view
				— designed for touch and desktop, built for creativity.
			</p>
		</div>
		<div class="features-grid">
			<FeatureCard
				icon="\u26A1"
				title="Capture ideas"
				description="Clips and patterns let you sketch musical ideas quickly. Perform rhythms, play melodies, and build from small pieces."
				images={["/images/placeholders/screen-1.svg", "/images/placeholders/screen-2.svg", "/images/placeholders/screen-3.svg"]}
			/>
			<FeatureCard
				icon="\u{1F39B}\uFE0F"
				title="Perform live"
				description="Launch scenes, play pads, and perform your music in real time. Every session is a performance."
				images={["/images/placeholders/screen-2.svg", "/images/placeholders/screen-4.svg", "/images/placeholders/screen-1.svg", "/images/placeholders/screen-3.svg"]}
			/>
			<FeatureCard
				icon="\u{1F3B9}"
				title="Build sounds"
				description="Synthesize instruments from FM patches, samplers, and drum kits. Over 650 built-in voices to start from."
				images={["/images/placeholders/screen-3.svg", "/images/placeholders/screen-1.svg", "/images/placeholders/screen-4.svg"]}
			/>
			<FeatureCard
				icon="\u{1F4F1}"
				title="Arrange anywhere"
				description="Full arrangement view to compose complete songs at the park or in the studio."
				images={["/images/placeholders/screen-4.svg", "/images/placeholders/screen-2.svg", "/images/placeholders/screen-3.svg", "/images/placeholders/screen-1.svg"]}
			/>
		</div>
	</GradientSection>

	<PageSection class="cta-section">
		<div class="cta-content">
			<h2>Ready to start creating?</h2>
			<p class="section-lead">
				Explore guides, read the manual, or join our community.
			</p>
			<div class="cta-cards">
				<a href="/learn/" class="cta-card">
					<span class="cta-card-icon">{"\u{1F4D6}"}</span>
					<span class="cta-card-title">Learn Pooly</span>
					<span class="cta-card-desc">Step-by-step guides for getting started</span>
				</a>
				<a href="/manual/" class="cta-card">
					<span class="cta-card-icon">{"\u{1F4DA}"}</span>
					<span class="cta-card-title">Manual</span>
					<span class="cta-card-desc">In-depth reference for every feature</span>
				</a>
				<a href="https://discord.gg/zbNVJYBtw7" class="cta-card" target="_blank" rel="noopener noreferrer">
					<span class="cta-card-icon">{"\u{1F4AC}"}</span>
					<span class="cta-card-title">Discord</span>
					<span class="cta-card-desc">Join the community and share your music</span>
				</a>
			</div>
		</div>
	</PageSection>
</BaseLayout>

<style>
	.hero {
		position: relative;
		min-height: 85svh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: var(--space-2xl) var(--space-md);
		overflow: hidden;
		isolation: isolate;
	}

	.hero-bg {
		position: absolute;
		inset: 0;
		background-image: url("/images/brand/poolyHero01.png");
		background-position: center;
		background-size: cover;
		background-repeat: no-repeat;
		z-index: -2;
	}

	/* .hero-bg::before,
	.hero-bg::after {
		content: "";
		position: absolute;
		inset: 0;
	}

	.hero-bg::before {
		background:
			linear-gradient(180deg, rgba(5, 7, 11, 0.06), rgba(5, 7, 11, 0.24)),
			linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px),
			linear-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px);
		background-size: auto, 48px 48px, 48px 48px;
		mix-blend-mode: screen;
		opacity: 0.22;
	}

	.hero-bg::after {
		background:
			radial-gradient(circle at 20% 18%, rgba(255, 255, 255, 0.14), transparent 28%),
			radial-gradient(circle at 84% 10%, rgba(120, 181, 255, 0.16), transparent 24%),
			linear-gradient(to bottom, transparent 60%, var(--color-bg));
	} */

	.hero-content {
		text-align: center;
		max-width: 36rem;
	}

	.hero-logo {
		width: min(28vw, 120px);
		height: auto;
		margin: 0 auto var(--space-xl);
		object-fit: contain;
	}

	.hero h1 {
		font-size: clamp(2.8rem, 10vw, 5rem);
		font-weight: 700;
		line-height: 0.95;
		letter-spacing: -0.04em;
		text-transform: lowercase;
		margin-bottom: var(--space-lg);
		text-shadow: 0 10px 30px var(--shadow-lg);
	}

	.hero-subtitle {
		font-size: clamp(var(--text-base), 2.5vw, var(--text-lg));
		color: var(--color-text);
		line-height: 1.6;
		max-width: 30rem;
		margin: 0 auto var(--space-2xl);
	}

	.social-links {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 0.25rem;
		width: 100%;
	}

	.social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		min-height: 3.25rem;
		padding: 0.85rem 1rem;
		border: none;
		border-radius: 0.5rem;
		background-color: var(--color-bg-glass-strong);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		box-shadow: var(--shadow-lg);
		text-decoration: none;
		text-transform: lowercase;
		font-size: 0.72rem;
		font-weight: 200;
		letter-spacing: 0.16em;
		color: var(--color-text);
		transition:
			transform 180ms ease,
			background-color 180ms ease;
	}

	.social-link:hover,
	.social-link:focus-visible {
		background-color: var(--color-bg-glass-strong);
		transform: translateY(-2px);
		color: var(--color-text);
	}

	.social-link:focus-visible {
		outline: 2px solid var(--color-text-soft);
		outline-offset: 3px;
	}

	.section-header {
		text-align: center;
		margin-bottom: var(--space-3xl);
	}

	.section-lead {
		color: var(--color-text-soft);
		font-size: var(--text-lg);
		max-width: 36rem;
		margin: var(--space-md) auto 0;
		line-height: 1.6;
	}

	.features-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-md);
	}

	.cta-section {
		text-align: center;
	}

	.cta-content {
		max-width: var(--content-max);
		margin: 0 auto;
	}

	.cta-cards {
		display: grid;
		grid-template-columns: 1fr;
		gap: var(--space-md);
		margin-top: var(--space-2xl);
		text-align: left;
	}

	.cta-card {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		padding: var(--space-xl);
		border-radius: var(--radius-lg);
		background: var(--color-bg-glass);
		border: 1px solid var(--color-border);
		color: var(--color-text);
		text-decoration: none;
		transition: all var(--duration-normal) var(--ease-out);
	}

	.cta-card:hover {
		background: var(--color-bg-glass-strong);
		border-color: var(--color-border-strong);
		transform: translateY(-2px);
		color: var(--color-text);
	}

	.cta-card-icon {
		font-size: 1.5rem;
	}

	.cta-card-title {
		font-family: var(--font-display);
		font-weight: 600;
		font-size: var(--text-lg);
	}

	.cta-card-desc {
		color: var(--color-text-soft);
		font-size: var(--text-sm);
	}

	@media (min-width: 40rem) {
		.features-grid {
			grid-template-columns: repeat(2, 1fr);
		}

		.cta-cards {
			grid-template-columns: repeat(3, 1fr);
		}

		.social-links {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (min-width: 64rem) {
		.social-links {
			grid-template-columns: repeat(6, minmax(0, 1fr));
		}
	}
</style>
