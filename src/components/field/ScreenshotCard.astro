---
interface Props {
	src: string;
	alt: string;
	class?: string;
}

const { src, alt, class: className } = Astro.props;
---

<figure class:list={["screenshot-card", className]}>
	<img src={src} alt={alt} loading="lazy" />
</figure>

<style>
	.screenshot-card {
		background: #080807;
		border: 1px solid rgba(255, 255, 255, 0.13);
		border-radius: 18px;
		padding: 0.5rem;
		margin: 0;
		box-shadow: var(--shadow-screenshot);
	}

	.screenshot-card img {
		width: 100%;
		display: block;
		border-radius: 12px;
	}
</style>
