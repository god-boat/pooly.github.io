---
interface Props {
	rotate?: string;
	class?: string;
	color?: "default" | "light" | "warm";
}

const { rotate = "-2deg", class: className, color = "default" } = Astro.props;
---

<span class:list={["tape-label", `tape-${color}`, className]} style={`--rotate:${rotate}`}>
	<svg class="tape-edge tape-left" viewBox="0 0 8 40" preserveAspectRatio="none" aria-hidden="true">
		<path d="M8 0 L8 40 L3 39.2 Q0 35 1 30 Q3 26 0 22 Q-1 18 2 14 Q3 10 1 6 Q0 3 3 0.8 Z" fill="currentColor" />
	</svg>
	<span class="tape-inner">
		<slot />
	</span>
	<svg class="tape-edge tape-right" viewBox="0 0 8 40" preserveAspectRatio="none" aria-hidden="true">
		<path d="M0 0 L0 40 L5 39.4 Q8 36 6 31 Q4 27 7 23 Q9 19 6 15 Q4 11 7 7 Q8 3 5 0.6 Z" fill="currentColor" />
	</svg>
</span>

<style>
	.tape-label {
		display: inline-flex;
		align-items: stretch;
		transform: rotate(var(--rotate));
		filter: drop-shadow(0 3px 8px rgba(0, 0, 0, 0.3));
		color: rgba(207, 190, 143, 0.88);
	}

	.tape-light {
		color: rgba(222, 212, 185, 0.72);
	}

	.tape-warm {
		color: rgba(200, 170, 110, 0.9);
	}

	.tape-edge {
		display: block;
		width: 8px;
		flex-shrink: 0;
	}

	.tape-inner {
		display: inline-flex;
		align-items: center;
		padding: 0.3rem 0.7rem;
		background: currentColor;
		color: #1b1710;
		font-size: 0.74rem;
		font-weight: 700;
		letter-spacing: 0.07em;
		text-transform: uppercase;
		white-space: nowrap;
		line-height: 1.3;
	}
</style>
