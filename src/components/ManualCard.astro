---
interface Props {
	title: string;
	description?: string;
	href: string;
}

const { title, description, href } = Astro.props;
---

<a href={href} class="manual-card">
	<h4 class="manual-card-title">{title}</h4>
	{description && <p class="manual-card-desc">{description}</p>}
	<span class="manual-card-arrow" aria-hidden="true">&rarr;</span>
</a>

<style>
	.manual-card {
		display: flex;
		flex-direction: column;
		padding: var(--space-lg);
		border-radius: var(--radius-md);
		background: var(--color-bg-glass);
		border: 1px solid var(--color-border);
		color: var(--color-text);
		text-decoration: none;
		transition: all var(--duration-normal) var(--ease-out);
		position: relative;
	}

	.manual-card:hover {
		background: var(--color-bg-glass-strong);
		border-color: var(--color-border-strong);
		color: var(--color-text);
	}

	.manual-card-title {
		font-size: var(--text-base);
		font-weight: 600;
		padding-right: var(--space-xl);
	}

	.manual-card-desc {
		color: var(--color-text-soft);
		font-size: var(--text-sm);
		margin-top: var(--space-xs);
		line-height: 1.5;
	}

	.manual-card-arrow {
		position: absolute;
		top: var(--space-lg);
		right: var(--space-lg);
		color: var(--color-text-muted);
		transition: transform var(--duration-fast) var(--ease-out);
	}

	.manual-card:hover .manual-card-arrow {
		transform: translateX(4px);
		color: var(--color-accent);
	}
</style>
