---

<footer class="footer">
	<div class="footer-inner">
		<nav class="footer-links" aria-label="Social links">
			{links.map(link => (
				<a href={link.href} class="footer-link" target="_blank" rel="noopener noreferrer" aria-label={link.label}>
					<Fragment set:html={link.icon} />
				</a>
			))}
		</nav>
		<img
			class="footer-mark"
			src="/images/brand/pooly_icon_windows_2.png"
			alt="Pooly"
			width="64"
			height="64"
			loading="lazy"
		/>
	</div>
</footer>

<style>
	.footer {
		border-top: 1px solid var(--color-border);
		padding: var(--space-2xl) var(--space-md);
	}

	.footer-inner {
		max-width: var(--content-max);
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: var(--space-lg);
	}

	.footer-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: var(--space-md) var(--space-lg);
	}

	.footer-link {
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-text-muted);
		transition: color var(--duration-fast) var(--ease-out);
	}

	.footer-link :global(svg) {
		width: 1.25rem;
		height: 1.25rem;
	}

	.footer-link:hover {
		color: var(--color-text);
	}

	.footer-mark {
		width: 2rem;
		height: 2rem;
		object-fit: contain;
		opacity: 0.7;
	}
</style>
