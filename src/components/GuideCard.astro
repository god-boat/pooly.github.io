---
interface Props {
	title: string;
	description: string;
	href: string;
	difficulty?: "beginner" | "intermediate" | "advanced";
	estimatedTime?: string;
}

const { title, description, href, difficulty = "beginner", estimatedTime } = Astro.props;
---

<a href={href} class="guide-card">
	<div class="guide-card-body">
		<h3 class="guide-title">{title}</h3>
		<p class="guide-desc">{description}</p>
	</div>
	<div class="guide-meta">
		<span class:list={["guide-difficulty", difficulty]}>{difficulty}</span>
		{estimatedTime && <span class="guide-time">{estimatedTime}</span>}
	</div>
</a>

<style>
	.guide-card {
		display: flex;
		flex-direction: column;
		padding: var(--space-xl);
		border-radius: var(--radius-2xl);
		background: var(--color-paper);
		border: 1px solid var(--color-border);
		color: var(--color-text);
		text-decoration: none;
		transition: all var(--duration-normal) var(--ease-out);
	}

	.guide-card:hover {
		background: var(--color-paper-soft);
		border-color: var(--color-border-strong);
		transform: translateY(-2px);
		color: var(--color-text);
	}

	.guide-card-body {
		flex: 1;
	}

	.guide-title {
		font-size: var(--text-lg);
		margin-bottom: var(--space-sm);
	}

	.guide-desc {
		color: var(--color-text-soft);
		font-size: var(--text-sm);
		line-height: 1.6;
	}

	.guide-meta {
		display: flex;
		gap: var(--space-md);
		align-items: center;
		margin-top: var(--space-lg);
		padding-top: var(--space-md);
		border-top: 1px solid var(--color-border);
	}

	.guide-difficulty {
		font-size: var(--text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 2px var(--space-sm);
		border-radius: var(--radius-sm);
		background: var(--color-accent-soft);
		color: var(--color-accent);
	}

	.guide-difficulty.intermediate {
		background: rgba(255, 200, 100, 0.16);
		color: rgb(255, 200, 100);
	}

	.guide-difficulty.advanced {
		background: rgba(255, 120, 150, 0.16);
		color: rgb(255, 120, 150);
	}

	.guide-time {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
	}
</style>
