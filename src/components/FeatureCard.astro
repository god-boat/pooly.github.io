---
import ImageStack from "./ImageStack.astro";

interface Props {
	icon: string;
	title: string;
	description: string;
	images?: string[];
}

const { icon, title, description, images } = Astro.props;
---

<div class="feature-card">
	{images && images.length > 0 && (
		<div class="feature-card-stack">
			<ImageStack images={images} />
		</div>
	)}
	<div class="feature-card-content">
		<span class="feature-icon">{icon}</span>
		<h3 class="feature-title">{title}</h3>
		<p class="feature-desc">{description}</p>
	</div>
</div>

<style>
	.feature-card {
		position: relative;
		padding: var(--space-xl);
		border-radius: var(--radius-lg);
		transition: all var(--duration-normal) var(--ease-out);
		overflow: visible;
	}

	.feature-card:hover {
		transform: translateY(-2px);
	}

	.feature-card-stack {
		position: absolute;
		inset: 0;
		z-index: 0;
		opacity: 0.35;
		pointer-events: none;
	}

	.feature-card-stack :global(.image-stack) {
		width: 100%;
		height: 100%;
		aspect-ratio: auto;
	}

	.feature-card-content {
		position: relative;
		z-index: 1;
		translate: 4px -4px;
	}

	.feature-icon {
		display: block;
		font-size: 2rem;
		margin-bottom: var(--space-md);
	}

	.feature-title {
		font-size: var(--text-lg);
		margin-bottom: var(--space-sm);
	}

	.feature-desc {
		color: var(--color-text-soft);
		font-size: var(--text-sm);
		line-height: 1.6;
	}
</style>
