---
import BaseLayout from "./BaseLayout.astro";
import { getCollection } from "astro:content";
import {
	compareManualNumbers,
	formatManualLabel,
	getManualChapter,
	manualChapters,
} from "../lib/manual-nav";

interface Props {
	title: string;
	description?: string;
	number: string;
	headings: Array<{ depth: number; slug: string; text: string }>;
}

interface ManualEntry {
	id: string;
	data: {
		number: string;
		title: string;
	};
}

const { title, description, number, headings } = Astro.props;

const allManual: ManualEntry[] = (await getCollection("manual", ({ data }) => !data.draft))
	.map(entry => ({
		id: entry.id,
		data: {
			number: String(entry.data.number),
			title: String(entry.data.title),
		},
	}))
	.sort((a, b) => compareManualNumbers(a.data.number, b.data.number));

const chapterNumber = getManualChapter(number);
const chapterTitle = manualChapters[chapterNumber];

const currentIndex = allManual.findIndex(e => e.data.number === number);
const prev = currentIndex > 0 ? allManual[currentIndex - 1] : null;
const next = currentIndex < allManual.length - 1 ? allManual[currentIndex + 1] : null;

const chapterNumbers: number[] = [
	...new Set(allManual.map(entry => getManualChapter(entry.data.number))),
].sort((a, b) => a - b);

type ManualHeading = (typeof headings)[number];

const pageHeadings: ManualHeading[] = headings.filter(
	heading => heading.depth === 2 || heading.depth === 3,
);
const headingSections: Array<{
	heading: ManualHeading;
	children: ManualHeading[];
	slugs: string[];
}> = [];
let currentHeadingSection: (typeof headingSections)[number] | null = null;

for (const heading of pageHeadings) {
	if (heading.depth === 2) {
		currentHeadingSection = {
			heading,
			children: [],
			slugs: [heading.slug],
		};
		headingSections.push(currentHeadingSection);
		continue;
	}

	if (currentHeadingSection && currentHeadingSection.heading.depth === 2) {
		currentHeadingSection.children.push(heading);
		currentHeadingSection.slugs.push(heading.slug);
		continue;
	}

	currentHeadingSection = {
		heading,
		children: [],
		slugs: [heading.slug],
	};
	headingSections.push(currentHeadingSection);
}
---

<BaseLayout title={`${number} ${title}`} description={description}>
	<div class="manual-page">
		<aside class="manual-sidebar">
			<details class="sidebar-drawer" open>
				<summary class="sidebar-toggle">
					<span>Navigation</span>
					<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
				</summary>
				<nav class="sidebar-nav" aria-label="Manual navigation">
					{chapterNumbers.map(chapter => {
						const entries = allManual.filter(
							entry => getManualChapter(entry.data.number) === chapter,
						);
						if (entries.length === 0) return null;

						const isSinglePageChapter =
							entries.length === 1 &&
							entries[0].data.number === String(chapter);

						const renderHeadingSections = () => (
							headingSections.length > 0 && (
								<ul class="sidebar-subsections" data-manual-heading-nav>
									{headingSections.map((section, index) => (
										<li
											class:list={[
												"sidebar-subsection",
												{ "is-expanded": index === 0 },
											]}
											data-manual-heading-section
											data-heading-slugs={section.slugs.join(" ")}
										>
											<a
												href={`#${section.heading.slug}`}
												class:list={[
													"sidebar-sub-link",
													{ "sidebar-sub-link-parent": section.heading.depth === 2 },
												]}
												data-manual-heading-link
												data-heading-slug={section.heading.slug}
											>
												{section.heading.text}
											</a>
											{section.children.length > 0 && (
												<ul class="sidebar-subtree">
													{section.children.map(child => (
														<li>
															<a
																href={`#${child.slug}`}
																class="sidebar-sub-link"
																data-manual-heading-link
																data-heading-slug={child.slug}
															>
																{child.text}
															</a>
														</li>
													))}
												</ul>
											)}
										</li>
									))}
								</ul>
							)
						);

						const headEntry = entries[0];
						const isHeadActive = headEntry.data.number === number;

						return (
							<div class="sidebar-section">
								<a
									href={`/manual/${headEntry.id}/`}
									class:list={[
										"sidebar-heading sidebar-heading-link",
										{ active: isHeadActive },
									]}
								>
									{chapter}. {manualChapters[chapter]}
								</a>
								{isHeadActive && renderHeadingSections()}
								{!isSinglePageChapter && (
									<ul class="sidebar-list">
										{entries.slice(1).map(entry => (
											<li>
												<a
													href={`/manual/${entry.id}/`}
													class:list={[
														"sidebar-link",
														{ active: entry.data.number === number },
													]}
												>
													{formatManualLabel(entry.data.number, entry.data.title)}
												</a>
												{entry.data.number === number && renderHeadingSections()}
											</li>
										))}
									</ul>
								)}
							</div>
						);
					})}
				</nav>
			</details>
		</aside>

		<article class="manual-article">
			<header class="article-header">
				<p class="article-section-label">{chapterNumber}. {chapterTitle}</p>
				<h1>{number} {title}</h1>
				{description && <p class="article-lead">{description}</p>}
			</header>

			<div class="article-content">
				<slot />
			</div>

			<nav class="article-nav" aria-label="Previous and next pages">
				{prev && (
					<a href={`/manual/${prev.id}/`} class="article-nav-link prev">
						<span class="nav-label">&larr; Previous</span>
						<span class="nav-title">
							{formatManualLabel(prev.data.number, prev.data.title)}
						</span>
					</a>
				)}
				{next && (
					<a href={`/manual/${next.id}/`} class="article-nav-link next">
						<span class="nav-label">Next &rarr;</span>
						<span class="nav-title">
							{formatManualLabel(next.data.number, next.data.title)}
						</span>
					</a>
				)}
			</nav>
		</article>
	</div>
</BaseLayout>

<script>
	const headingNav = document.querySelector("[data-manual-heading-nav]");

	if (headingNav instanceof HTMLElement) {
		const sections = Array.from(
			headingNav.querySelectorAll<HTMLElement>("[data-manual-heading-section]"),
		);
		const links = Array.from(
			headingNav.querySelectorAll<HTMLAnchorElement>("[data-manual-heading-link]"),
		);

		const slugs: string[] = [];
		const headingElements = new Map<string, HTMLElement>();

		for (const link of links) {
			const slug = link.dataset.headingSlug ?? "";
			if (!slug || headingElements.has(slug)) continue;
			const target = document.getElementById(slug);
			if (target instanceof HTMLElement) {
				slugs.push(slug);
				headingElements.set(slug, target);
			}
		}

		const applyActiveSlug = (activeSlug: string) => {
			let expandedSection: HTMLElement | null = null;

			if (activeSlug.length > 0) {
				expandedSection =
					sections.find(section => {
						const sectionSlugs = (section.dataset.headingSlugs ?? "")
							.split(" ")
							.filter(Boolean);
						return sectionSlugs.includes(activeSlug);
					}) ?? null;
			}

			if (!expandedSection && sections.length > 0) {
				expandedSection = sections[0];
			}

			for (const section of sections) {
				section.classList.toggle("is-expanded", section === expandedSection);
			}

			for (const link of links) {
				const isActive = activeSlug.length > 0 && link.dataset.headingSlug === activeSlug;
				link.classList.toggle("active", isActive);
			}
		};

		const computeActiveSlugFromScroll = (): string => {
			if (slugs.length === 0) return "";

			// Treat a heading as "current" once its top has crossed the offset line.
			const offset = Math.max(96, window.innerHeight * 0.2);
			let activeSlug = slugs[0];

			for (const slug of slugs) {
				const el = headingElements.get(slug);
				if (!el) continue;
				const top = el.getBoundingClientRect().top;
				if (top - offset <= 0) {
					activeSlug = slug;
				} else {
					break;
				}
			}

			// At the very bottom of the page, force-activate the last heading
			// in case its top never crosses the offset line.
			const nearBottom =
				window.innerHeight + window.scrollY >=
				document.documentElement.scrollHeight - 4;
			if (nearBottom) {
				activeSlug = slugs[slugs.length - 1];
			}

			return activeSlug;
		};

		let lastSlug = "";
		let ticking = false;

		const updateFromScroll = () => {
			ticking = false;
			const slug = computeActiveSlugFromScroll();
			if (slug === lastSlug) return;
			lastSlug = slug;
			applyActiveSlug(slug);
		};

		const onScroll = () => {
			if (ticking) return;
			ticking = true;
			window.requestAnimationFrame(updateFromScroll);
		};

		// Initial state: derive from hash if present, otherwise from scroll.
		const initialHash = decodeURIComponent(window.location.hash).replace(/^#/, "");
		if (initialHash && headingElements.has(initialHash)) {
			lastSlug = initialHash;
			applyActiveSlug(initialHash);
		} else {
			updateFromScroll();
		}

		window.addEventListener("scroll", onScroll, { passive: true });
		window.addEventListener("resize", onScroll, { passive: true });

		// When the user clicks an in-page link, honor that selection immediately
		// rather than waiting for the browser's scroll to settle.
		for (const link of links) {
			link.addEventListener("click", () => {
				const slug = link.dataset.headingSlug ?? "";
				if (!slug) return;
				lastSlug = slug;
				applyActiveSlug(slug);
			});
		}

		window.addEventListener("hashchange", () => {
			const slug = decodeURIComponent(window.location.hash).replace(/^#/, "");
			if (slug && headingElements.has(slug)) {
				lastSlug = slug;
				applyActiveSlug(slug);
			}
		});
	}
</script>

<style>
	.manual-page {
		max-width: var(--content-max);
		margin: 0 auto;
		display: grid;
		grid-template-columns: 1fr;
		gap: 0;
		padding: var(--space-md);
	}

	.manual-sidebar {
		order: 2;
		margin-top: var(--space-xl);
		margin-bottom: 0;
	}

	.manual-article {
		order: 1;
	}

	.sidebar-drawer {
		border: 1px solid var(--color-border);
		border-radius: var(--radius-md);
		background: var(--color-bg-glass);
	}

	.sidebar-toggle {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding: var(--space-md) var(--space-lg);
		cursor: pointer;
		font-family: var(--font-display);
		font-size: var(--text-sm);
		font-weight: 600;
		list-style: none;
	}

	.sidebar-toggle::-webkit-details-marker {
		display: none;
	}

	.sidebar-nav {
		padding: 0 var(--space-lg) var(--space-lg);
	}

	.sidebar-section {
		margin-bottom: var(--space-lg);
	}

	.sidebar-section:last-child {
		margin-bottom: 0;
	}

	.sidebar-heading {
		font-size: var(--text-xs);
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-text-muted);
		margin-bottom: var(--space-sm);
	}

	.sidebar-heading-link {
		display: block;
		padding: var(--space-xs) var(--space-sm);
		border-radius: var(--radius-sm);
		margin-bottom: 0;
		transition: all var(--duration-fast) var(--ease-out);
	}

	.sidebar-heading-link:hover {
		color: var(--color-text);
		background: var(--color-bg-surface);
	}

	.sidebar-heading-link.active {
		color: var(--color-accent);
		background: var(--color-accent-soft);
	}

	.sidebar-list {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.sidebar-link {
		display: block;
		padding: var(--space-xs) var(--space-sm);
		border-radius: var(--radius-sm);
		color: var(--color-text-soft);
		font-size: var(--text-sm);
		transition: all var(--duration-fast) var(--ease-out);
	}

	.sidebar-link:hover {
		color: var(--color-text);
		background: var(--color-bg-surface);
	}

	.sidebar-link.active {
		color: var(--color-accent);
		background: var(--color-accent-soft);
	}

	.sidebar-subsections {
		list-style: none;
		display: flex;
		flex-direction: column;
		gap: 2px;
		margin-top: var(--space-xs);
		padding-left: var(--space-md);
	}

	.sidebar-subsection {
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.sidebar-subtree {
		list-style: none;
		display: none;
		flex-direction: column;
		gap: 2px;
		padding-left: var(--space-md);
	}

	.sidebar-subsection.is-expanded .sidebar-subtree {
		display: flex;
	}

	.sidebar-sub-link {
		display: block;
		padding: 2px var(--space-xs);
		border-radius: var(--radius-sm);
		color: var(--color-text-muted);
		font-size: var(--text-xs);
		line-height: 1.4;
		transition: all var(--duration-fast) var(--ease-out);
	}

	.sidebar-sub-link-parent {
		color: var(--color-text-soft);
		font-weight: 600;
	}

	.sidebar-sub-link:hover {
		color: var(--color-text);
		background: var(--color-bg-surface);
	}

	.sidebar-sub-link.active {
		color: var(--color-accent);
		background: var(--color-accent-soft);
	}

	.article-header {
		margin-bottom: var(--space-2xl);
	}

	.article-section-label {
		font-size: var(--text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-accent);
		margin-bottom: var(--space-sm);
	}

	.article-header h1 {
		font-size: clamp(var(--text-2xl), 5vw, var(--text-3xl));
		margin-bottom: var(--space-md);
	}

	.article-lead {
		font-size: var(--text-lg);
		color: var(--color-text-soft);
		line-height: 1.6;
	}

	.article-content {
		line-height: 1.7;
	}

	.article-content :global(h2) {
		margin-top: var(--space-3xl);
		margin-bottom: var(--space-md);
		padding-bottom: var(--space-sm);
		border-bottom: 1px solid var(--color-border);
	}

	.article-content :global(h3) {
		margin-top: var(--space-2xl);
		margin-bottom: var(--space-sm);
	}

	.article-content :global(p) {
		margin-bottom: var(--space-md);
	}

	.article-content :global(ul),
	.article-content :global(ol) {
		margin-bottom: var(--space-md);
		padding-left: var(--space-xl);
	}

	.article-content :global(li) {
		margin-bottom: var(--space-xs);
	}

	.article-content :global(li + li) {
		margin-top: var(--space-xs);
	}

	.article-content :global(strong) {
		color: var(--color-text);
		font-weight: 600;
	}

	.article-nav {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: var(--space-md);
		margin-top: var(--space-3xl);
		padding-top: var(--space-xl);
		border-top: 1px solid var(--color-border);
	}

	.article-nav-link {
		display: flex;
		flex-direction: column;
		gap: var(--space-xs);
		padding: var(--space-lg);
		border-radius: var(--radius-md);
		border: 1px solid var(--color-border);
		color: var(--color-text);
		text-decoration: none;
		transition: all var(--duration-fast) var(--ease-out);
	}

	.article-nav-link:hover {
		border-color: var(--color-border-strong);
		background: var(--color-bg-surface);
		color: var(--color-text);
	}

	.article-nav-link.next {
		text-align: right;
		grid-column: 2;
	}

	.nav-label {
		font-size: var(--text-xs);
		color: var(--color-text-muted);
	}

	.nav-title {
		font-size: var(--text-sm);
		font-weight: 600;
	}

	@media (min-width: 64rem) {
		.manual-page {
			grid-template-columns: 15rem 1fr;
			gap: var(--space-2xl);
			padding: var(--space-xl) var(--space-2xl);
		}

		.manual-sidebar {
			order: 0;
			position: sticky;
			top: 4rem;
			max-height: calc(100svh - 5rem);
			overflow-y: auto;
			margin-top: 0;
			margin-bottom: 0;
		}

		.manual-article {
			order: 0;
		}

		.sidebar-drawer {
			border: none;
			background: none;
		}

		.sidebar-toggle {
			display: none;
		}

		.manual-article {
			max-width: var(--article-max);
		}
	}

	@media (min-width: 80rem) {
		.manual-page {
			grid-template-columns: 16rem 1fr;
			gap: var(--space-3xl);
		}
	}
</style>
