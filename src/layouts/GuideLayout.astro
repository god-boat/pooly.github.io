---
import BaseLayout from "./BaseLayout.astro";

interface Props {
	title: string;
	description: string;
	difficulty?: "beginner" | "intermediate" | "advanced";
	estimatedTime?: string;
}

const { title, description, difficulty = "beginner", estimatedTime } = Astro.props;
---

<BaseLayout title={title} description={description}>
	<div class="guide-page">
		<article class="guide-article">
			<header class="guide-header">
				<a href="/learn/" class="guide-back">&larr; Back to Learn</a>
				<h1>{title}</h1>
				<p class="guide-lead">{description}</p>
				<div class="guide-meta">
					<span class:list={["guide-difficulty", difficulty]}>{difficulty}</span>
					{estimatedTime && <span class="guide-time">{estimatedTime}</span>}
				</div>
			</header>

			<div class="guide-content">
				<slot />
			</div>
		</article>
	</div>
</BaseLayout>

<style>
	.guide-page {
		max-width: var(--article-max);
		margin: 0 auto;
		padding: var(--space-xl) var(--space-md);
	}

	.guide-back {
		display: inline-block;
		font-size: var(--text-sm);
		color: var(--color-text-muted);
		margin-bottom: var(--space-lg);
		transition: color var(--duration-fast) var(--ease-out);
	}

	.guide-back:hover {
		color: var(--color-text);
	}

	.guide-header {
		margin-bottom: var(--space-2xl);
	}

	.guide-header h1 {
		font-size: clamp(var(--text-2xl), 5vw, var(--text-3xl));
		margin-bottom: var(--space-md);
	}

	.guide-lead {
		font-size: var(--text-lg);
		color: var(--color-text-soft);
		line-height: 1.6;
		margin-bottom: var(--space-lg);
	}

	.guide-meta {
		display: flex;
		gap: var(--space-md);
		align-items: center;
	}

	.guide-difficulty {
		font-size: var(--text-xs);
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 2px var(--space-sm);
		border-radius: var(--radius-sm);
		background: var(--color-accent-soft);
		color: var(--color-accent);
	}

	.guide-difficulty.intermediate {
		background: rgba(255, 200, 100, 0.16);
		color: rgb(255, 200, 100);
	}

	.guide-difficulty.advanced {
		background: rgba(255, 120, 150, 0.16);
		color: rgb(255, 120, 150);
	}

	.guide-time {
		font-size: var(--text-sm);
		color: var(--color-text-muted);
	}

	.guide-content {
		line-height: 1.7;
	}

	.guide-content :global(h2) {
		margin-top: var(--space-3xl);
		margin-bottom: var(--space-md);
	}

	.guide-content :global(h3) {
		margin-top: var(--space-2xl);
		margin-bottom: var(--space-sm);
	}

	.guide-content :global(p) {
		margin-bottom: var(--space-md);
	}

	.guide-content :global(ul),
	.guide-content :global(ol) {
		margin-bottom: var(--space-md);
		padding-left: var(--space-xl);
	}

	.guide-content :global(li) {
		margin-bottom: var(--space-xs);
	}

	.guide-content :global(li + li) {
		margin-top: var(--space-xs);
	}

	.guide-content :global(strong) {
		color: var(--color-text);
		font-weight: 600;
	}

	@media (min-width: 40rem) {
		.guide-page {
			padding: var(--space-2xl) var(--space-xl);
		}
	}
</style>
